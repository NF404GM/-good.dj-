generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Track {
  id        String   @id @default(uuid())
  title     String
  artist    String
  album     String
  genre     String
  bpm       Float
  key       String
  duration  Float
  rating    Int      @default(0)
  dateAdded DateTime @default(now())
  analyzed  Boolean  @default(false)
  
  // Track specific features
  beatsJson String?  // JSON stringified array of beat floats
  filePath  String?  // Path to the actual uploaded audio file on the server

  // Relations
  playlistTracks PlaylistTrack[]
  cuePoints      CuePoint[]
}

model Playlist {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  
  // Relations
  tracks    PlaylistTrack[]
}

model PlaylistTrack {
  playlistId String
  trackId    String
  order      Int      @default(0)
  
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@id([playlistId, trackId])
}

model CuePoint {
  id       String @id @default(uuid())
  trackId  String
  index    Int     // 0-7 for hotcues
  position Float  // Position in seconds
  
  track    Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([trackId, index]) // A track can have only one cue point per index
}
