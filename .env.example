# good.dj Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Gumroad product permalink (found in Gumroad Dashboard -> Products -> [good.dj] -> Permalink)
VITE_GUMROAD_PRODUCT_ID=your_gumroad_permalink_here

# Dev server port (default 3003 - only change if you have a port conflict)
VITE_SERVER_PORT=3003
