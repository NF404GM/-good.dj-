{
    "name": "good.dj",
    "private": true,
    "version": "1.0.0",
    "description": "Professional DJ software with real-time stem separation, beat analysis, and MIDI control.",
    "author": "good. Company",
    "license": "SEE LICENSE IN LICENSE.md",
    "type": "module",
    "main": "electron-dist/main.js",
    "scripts": {
        "start": "concurrently \"npm run backend\" \"npm run dev\"",
        "dev": "vite --strictPort --port 5173",
        "backend": "npx tsx server/index.ts",
        "build": "vite build",
        "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --external:@prisma/client --external:prolink-connect --external:ws --external:express --external:multer --external:cors --outfile=server-dist/index.js",
        "build:electron": "node scripts/build-electron.mjs",
        "stems:download-test-model": "node scripts/download-demucs-model.mjs",
        "electron:dev": "npm run build:electron && cross-env NODE_ENV=development concurrently \"npm run dev\" \"wait-on tcp:5173 && cross-env NODE_OPTIONS=--import=tsx electron electron/main.ts\"",
        "electron:build": "npm run build && npm run build:server && npm run build:electron && electron-builder --config electron-builder.config.cjs",
        "electron:build:free-with-stem-model": "cross-env GOODDJ_BUNDLE_STEM_MODEL=1 npm run electron:build && node scripts/finalize-free-release.mjs",
        "preview": "vite preview",
        "lint": "eslint . --ext .ts,.tsx",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "check": "npm run lint && npm run typecheck && npm run test && npm run build",
        "postinstall": "prisma generate && npx electron-rebuild"
    },
    "build": {
        "appId": "com.goodcompany.gooddj",
        "productName": "good.DJ",
        "copyright": "Copyright © 2026 good. Company",
        "files": [
            "dist/**/*",
            "server-dist/**/*",
            "electron-dist/**/*",
            "bin/**/*",
            "package.json"
        ],
        "asarUnpack": [
            "bin/**/*.exe"
        ],
        "toolsets": {
            "winCodeSign": "1.1.0"
        },
        "npmRebuild": true,
        "directories": {
            "buildResources": "assets",
            "output": "release"
        },
        "mac": {
            "target": [
                "dmg"
            ],
            "icon": "assets/icon.png"
        },
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "assets/icon.ico",
            "signAndEditExecutable": false
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico",
            "installerHeaderIcon": "assets/icon.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "good.DJ"
        }
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@prisma/client": "6.19.2",
        "cors": "^2.8.6",
        "essentia.js": "^0.1.3",
        "express": "^5.2.1",
        "framer-motion": "^12.35.0",
        "immer": "^11.1.4",
        "multer": "^2.1.1",
        "node-web-audio-api": "^1.0.7",
        "onnxruntime-node": "^1.23.2",
        "p-queue": "^9.1.0",
        "prolink-connect": "^0.11.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "signalsmith-stretch": "^1.3.2",
        "tunajs": "^1.1.3",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "@tailwindcss/postcss": "^4.2.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^22.14.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/tunajs": "^1.0.3",
        "@types/ws": "^8.18.1",
        "@vitejs/plugin-react": "^5.0.0",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "esbuild": "^0.27.4",
        "eslint": "^9.22.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "jsdom": "^28.1.0",
        "node-gyp": "^12.2.0",
        "postcss": "^8.5.8",
        "prisma": "6.19.2",
        "tailwindcss": "^4.2.1",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "~5.8.2",
        "typescript-eslint": "^8.26.0",
        "vite": "^6.2.0",
        "vitest": "^4.1.0",
        "wait-on": "^9.0.4"
    },
    "overrides": {
        "prolink-connect": {
            "better-sqlite3": "12.6.2"
        }
    }
}
