{
    "name": "good.dj",
    "private": true,
    "version": "1.0.0",
    "description": "The first fully web-native DJ application with real-time beat analysis, MIDI control, and stem filtering.",
    "author": "good. Company",
    "license": "SEE LICENSE IN LICENSE.md",
    "type": "module",
    "scripts": {
        "dev": "vite --strictPort --port 5173",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext .ts,.tsx",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "check": "npm run lint && npm run typecheck && npm run test && npm run build"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "essentia.js": "^0.1.3",
        "framer-motion": "^12.35.0",
        "immer": "^11.1.4",
        "p-queue": "^9.1.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "signalsmith-stretch": "^1.3.2",
        "tunajs": "^1.1.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "@types/node": "^22.14.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/tunajs": "^1.0.3",
        "@vitejs/plugin-react": "^5.0.0",
        "autoprefixer": "^10.4.27",
        "esbuild": "^0.27.4",
        "eslint": "^9.22.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "jsdom": "^28.1.0",
        "postcss": "^8.5.8",
        "tailwindcss": "^4.2.1",
        "typescript": "~5.8.2",
        "typescript-eslint": "^8.26.0",
        "vite": "^6.2.0",
        "vitest": "^4.1.0"
    }
